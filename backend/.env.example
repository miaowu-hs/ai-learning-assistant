# Copy this file to .env before starting the backend.

MYSQL_URL=jdbc:mysql://localhost:3306/ai_learning_assistant?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false&createDatabaseIfNotExist=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me

JWT_SECRET_KEY=replace-with-a-random-string-at-least-32-characters-long

# AI provider settings
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com
DASHSCOPE_CHAT_COMPLETIONS_PATH=/v1/chat/completions
DASHSCOPE_MODEL=qwen3.5-plus
